APP_PORT=80

# Set this to your public domain in production.
CORS_ORIGINS=https://your-domain.com

# Primary model configuration
PRIMARY_LLM_PROVIDER=anthropic
PRIMARY_LLM_API_KEY=replace-me
PRIMARY_LLM_BASE_URL=https://api.minimaxi.com/anthropic
PRIMARY_LLM_MODEL=MiniMax-M2.5

# Backup model configuration
BACKUP_LLM_PROVIDER=openai
BACKUP_LLM_API_KEY=replace-me
BACKUP_LLM_BASE_URL=http://www.zettacore.cyou/v1
BACKUP_LLM_MODEL=glm-4.5-air

# Optional services
MEM0_API_KEY=
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
RAG_ENABLED=false
RAG_EMBEDDING_MODEL=text-embedding-3-small
KNOWLEDGE_DIR=./data/knowledge

# Runtime tuning
LLM_TIMEOUT_SECONDS=60
APP_NAME=Debate Agent
DEBUG=false
